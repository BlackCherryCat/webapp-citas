# .htaccess — Slim front controller & basic hardening
# Place this file in webapp-citas/packages/backend/public/.htaccess
#
# Behavior:
# - Serves existing files/directories directly
# - Rewrites other requests to index.php (Slim front controller)
# - Blocks access to dotfiles and common sensitive files
# - Adds basic security headers and disables directory listing

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Deny access to any "hidden" file (starting with a dot)
    RewriteRule (^|/)\. - [F]

    # Deny direct access to sensitive top-level files
    RewriteRule ^(composer\.(json|lock)|\.env|bootstrap\.php|README|LICENSE|CHANGELOG)$ - [F,L,NC]

    # If the request maps to an existing file or directory, serve it as-is
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Otherwise, forward request to the Slim front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Disable directory listings
Options -Indexes

# Basic security headers (adjust or extend as needed)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    # Uncomment to enable HSTS once you have HTTPS correctly configured:
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# Deny access to sensitive files for Apache 2.4+
<IfModule mod_authz_core.c>
    <FilesMatch "^(\.env|composer\.(json|lock)|README|LICENSE|CHANGELOG)($|\.)">
        Require all denied
    </FilesMatch>
</IfModule>

# Compatibility for older Apache versions (<2.4)
<IfModule !mod_authz_core.c>
    <FilesMatch "^(\.env|composer\.(json|lock)|README|LICENSE|CHANGELOG)($|\.)">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>
